# Copiar a .env.local y reemplazar con valores reales (nunca commitear .env.local)

# Google Apps Script — Web App URL
# VITE_SHEET_URL=https://script.google.com/macros/s/XXXX/exec

# Gemini API Key — Google AI Studio
# VITE_GEMINI_API_KEY=AIzaSy...

# Google Drive — IDs de carpetas (segmento de drive.google.com/drive/folders/ID)
# VITE_DRIVE_FOLDER_REMITOS=
# VITE_DRIVE_FOLDER_FACTURAS=
